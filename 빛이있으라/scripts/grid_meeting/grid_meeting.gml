// Script assets have changed for v2.3.0 see
// https://help.yoyogames.com/hc/en-us/articles/360005277377 for more information
function grid_meeting(){
	if(room = Room1){
		return grid_place_meeting(self,o_level_0.grid_);
	}
	if(room = Room2){
		return grid_place_meeting(self,o_level_1.grid_);
	}
	if(room = Room3){
		return grid_place_meeting(self,o_level_2.grid_);
	}
	if(room = Room4){
		return grid_place_meeting(self,o_level_3.grid_);
	}
	if(room = Room5){
		return grid_place_meeting(self,o_level_4.grid_);
	}
	if(room = Room6){
		return grid_place_meeting(self,o_level_5.grid_);
	}
	if(room = Room7){
		return grid_place_meeting(self,o_level_6.grid_);
	}
	if(room = Room8){
		return grid_place_meeting(self,o_level_7.grid_);
	}
	if(room = Room9){
		return grid_place_meeting(self,o_level_8.grid_);
	}
	if(room = Room10){
		return grid_place_meeting(self,o_level_9.grid_);
	}

}