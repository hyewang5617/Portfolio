function Enemy_Number() {
	if(room = Room1){
		o_level_0.Enemy_num -= 1;
	}
	if(room = Room2){
		o_level_1.Enemy_num -= 1;
	}
	if(room = Room3){
		o_level_2.Enemy_num -= 1;
	}
	if(room = Room4){
		o_level_3.Enemy_num -= 1;
	}
	if(room = Room5){
		o_level_4.Enemy_num -= 1;
	}
	if(room = Room6){
		o_level_5.Enemy_num -= 1;
	}
	if(room = Room7){
		o_level_6.Enemy_num -= 1;
	}
	if(room = Room8){
		o_level_7.Enemy_num -= 1;
	}
	if(room = Room9){
		o_level_8.Enemy_num -= 1;
	}
	if(room = Room10){
		o_level_9.Enemy_num -= 1;
	}
}
